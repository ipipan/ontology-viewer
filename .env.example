# =============================================================================
# Ontology Viewer — Deployment Configuration
# =============================================================================
# Copy this file to .env and adjust values before deploying:
#   cp .env.example .env
# =============================================================================

# Domain name for the nginx server and SSL certificate
DOMAIN_NAME=example.com

# Data directory (relative to project root)
DATA_DIR=./data

# Backend settings
BACKEND_PORT=8000
BACKEND_WORKERS=2

# CORS allowed origins (comma-separated)
# Automatically includes https://${DOMAIN_NAME} in production
ALLOWED_ORIGINS=https://example.com

# Compose project name
COMPOSE_PROJECT_NAME=ontology-viewer
