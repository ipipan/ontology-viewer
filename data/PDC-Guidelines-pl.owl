<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Synchrony_3">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Synchrony"/>
    <rdfs:label>Gdy wszyscy spali, zdezorientowany nietoperz wtargnął z impetem do sypialni.</rdfs:label>

    <skos:notation>PDC-G 46</skos:notation>

    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_gdy_2">
