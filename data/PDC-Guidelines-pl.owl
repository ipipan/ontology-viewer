            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasExpander>
</owl:NamedIndividual>


<!-- FUNCTIONAL DEPENDENCE -->

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_FunctionalDependence">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#FunctionalDependence"/>
    <rdfs:label>— No jak, odpowiada wam? — Owszem, odpowiada.</rdfs:label>

    <skos:notation>PDC-G 53</skos:notation>

    <hasAntecedentAct>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_AntecedentAct_1">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#AntecedentAct"/>
            <rdfs:label>— No jak, odpowiada wam?</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</skos:order>
        </owl:NamedIndividual>
    </hasAntecedentAct>
    <hasDependentAct>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_DependentAct_1">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#DependentAct"/>
            <rdfs:label>— Owszem, odpowiada.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasDependentAct>
</owl:NamedIndividual>


