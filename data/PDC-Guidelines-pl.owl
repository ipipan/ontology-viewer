<?xml version="1.0"?>
<rdf:RDF xmlns="http://purl.org/olia/discourse/discourse.ISO.PL.owl#"
     xml:base="http://purl.org/olia/discourse/discourse.ISO.PL.owl"
     xmlns:iso="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:owl2xml="http://www.w3.org/2006/12/owl2-xml#">

    <owl:Ontology rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl">
        <rdfs:comment xml:lang="en">Corpus examples in Polish representing various relations of the ISO ontology.</rdfs:comment>
    </owl:Ontology>

<!-- CAUSE -->

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Cause">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Cause"/>
    <rdfs:label>Las jest także olbrzymią fabryką tlenu, więc zapewnia komfort oddychania.</rdfs:label>

    <skos:notation>PDC-G 1</skos:notation>

    <hasReason>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Reason_1">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Reason"/>
            <rdfs:label>Las jest także olbrzymią fabryką tlenu,</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</skos:order>
        </owl:NamedIndividual>
    </hasReason>
    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_wiec">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>więc</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasResult>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Result_1">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Result"/>
            <rdfs:label>zapewnia komfort oddychania.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasResult>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Cause_2">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Cause"/>
    <rdfs:label>W nowym biurowcu użytkownicy będą czuć się bezpiecznie, ponieważ zostanie on objęty całodobową ochroną.</rdfs:label>

    <skos:notation>PDC-G 2</skos:notation>

    <hasResult>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Result_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Result"/>
            <rdfs:label>W nowym biurowcu użytkownicy będą czuć się bezpiecznie,</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</skos:order>
        </owl:NamedIndividual>
    </hasResult>
    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_poniewaz">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>ponieważ</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasReason>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Reason_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Reason"/>
            <rdfs:label>zostanie on objęty całodobową ochroną.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasReason>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Cause_3">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Cause" />
    <rdfs:label>Nie wykonali zadania w terminie, więc zostali wezwani do kierowniczki.</rdfs:label>

    <skos:notation>PDC-G 3</skos:notation>

    <hasReason>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Reason_3">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Reason"/>
            <rdfs:label>Nie wykonali zadania w terminie,</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</skos:order>
        </owl:NamedIndividual>
    </hasReason>
    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_wiec_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>więc</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasResult>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Result_3">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Result"/>
            <rdfs:label>zostali wezwani do kierowniczki.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasResult>
</owl:NamedIndividual>


<!-- CONDITION -->

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Condition_1">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Condition"/>
    <rdfs:label>Świat zmieniłby się w koszmar, gdyby małżonkowie widzieli w swoim dziecku tylko ciężar i zagrożenie.</rdfs:label>

    <skos:notation>PDC-G 4</skos:notation>

    <hasConsequent>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Consequent_1">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Consequent"/>
            <rdfs:label>Świat zmieniłby się w koszmar,</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</skos:order>
        </owl:NamedIndividual>
    </hasConsequent>
    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_gdyby_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>gdyby</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasAntecedent>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Antecedent_1">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Antecedent"/>
            <rdfs:label>małżonkowie widzieli w swoim dziecku tylko ciężar i zagrożenie.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasAntecedent>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Condition_2">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Condition"/>
    <rdfs:label>Jeśli pieniądze te dostaną, atmosfera w placówkach szpitalnych ulegnie poprawie.</rdfs:label>

    <skos:notation>PDC-G 5</skos:notation>

    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_jesli">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>Jeśli</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasAntecedent>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Antecedent_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Antecedent"/>
            <rdfs:label>pieniądze te dostaną,</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasAntecedent>
    <hasConsequent>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Consequent_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Consequent"/>
            <rdfs:label>atmosfera w placówkach szpitalnych ulegnie poprawie.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasConsequent>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Condition_3">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Condition" />
    <rdfs:label>Gdyby pogoda była lepsza, mogłaby wyjść na rower.</rdfs:label>

    <skos:notation>PDC-G 6</skos:notation>

    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_gdyby">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>Gdyby</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasAntecedent>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Antecedent_3">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Antecedent"/>
            <rdfs:label>pogoda była lepsza,</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasAntecedent>
    <hasConsequent>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Consequent_3">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Consequent"/>
            <rdfs:label>mogłaby wyjść na rower.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasConsequent>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Condition_4">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Condition" />
    <rdfs:label>Jeśli nie bedzie świecić słońce, to nie wyjdę na rower.</rdfs:label>

    <skos:notation>PDC-G 7</skos:notation>

    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_jesli_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>Jeśli</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasAntecedent>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Antecedent_4">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Antecedent"/>
            <rdfs:label>nie bedzie świecić słońce,</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasAntecedent>
    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_to_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>to</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasConsequent>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Consequent_4">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Consequent"/>
            <rdfs:label>nie wyjdę na rower.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</skos:order>
        </owl:NamedIndividual>
    </hasConsequent>
</owl:NamedIndividual>



<!-- NEGATIVE CONDITION -->

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_NegativeCondition_1">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#NegativeCondition"/>
    <rdfs:label>Mamy prawo odmówić dalszych napraw i zażądać zwrotu pieniędzy, chyba że wada nie była istotna.</rdfs:label>

    <skos:notation>PDC-G 8</skos:notation>

    <hasConsequentOfNegativeCondition>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_ConsequentOfNegativeCondition_1">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#ConsequentOfNegativeCondition"/>
            <rdfs:label>Mamy prawo odmówić dalszych napraw i zażądać zwrotu pieniędzy,</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</skos:order>
        </owl:NamedIndividual>
    </hasConsequentOfNegativeCondition>
    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_chyba_ze_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>chyba że</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasNegatedAntecedent>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_NegatedAntecedent_1">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#NegatedAntecedent"/>
            <rdfs:label>wada nie była istotna.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasNegatedAntecedent>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_NegativeCondition_2">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#NegativeCondition"/>
    <rdfs:label>Jeśli fundusz rezerwowy nie zostanie wykorzystany, to zostanie oddany „do Warszawy”.</rdfs:label>

    <skos:notation>PDC-G 9</skos:notation>

    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_jesli">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>Jeśli</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasNegatedAntecedent>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_NegatedAntecedent_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#NegatedAntecedent"/>
            <rdfs:label>fundusz rezerwowy nie zostanie wykorzystany,</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasNegatedAntecedent>
    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_to">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>to</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasConsequentOfNegativeCondition>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_ConsequentOfNegativeCondition_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#ConsequentOfNegativeCondition"/>
            <rdfs:label>zostanie oddany „do Warszawy”.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</skos:order>
        </owl:NamedIndividual>
    </hasConsequentOfNegativeCondition>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_NegativeCondition_3">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#NegativeCondition"/>
    <rdfs:label>Nie pójdziemy na plażę, chyba że będzie ciepło.</rdfs:label>

    <skos:notation>PDC-G 10</skos:notation>

    <hasConsequentOfNegativeCondition>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_ConsequentOfNegativeCondition_3">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#ConsequentOfNegativeCondition"/>
            <rdfs:label>Nie pójdziemy na plażę</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</skos:order>
        </owl:NamedIndividual>
    </hasConsequentOfNegativeCondition>
    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_chyba_ze_3">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>chyba że</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasNegatedAntecedent>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_NegatedAntecedent_3">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#NegatedAntecedent"/>
            <rdfs:label>będzie ciepło.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasNegatedAntecedent>
</owl:NamedIndividual>


<!-- PURPOSE -->

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Purpose_2">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Purpose"/>
    <rdfs:label>Aby skorygować błędy w sposobie myślenia, zacznij prowadzić wykaz codziennych zajęć.</rdfs:label>

    <skos:notation>PDC-G 11</skos:notation>

    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_aby">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>Aby</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasGoal>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Goal_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Goal"/>
            <rdfs:label>skorygować błędy w sposobie myślenia,</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasGoal>
    <hasEnablement>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Enablement_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Enablement"/>
            <rdfs:label>zacznij prowadzić wykaz codziennych zajęć.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasEnablement>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Purpose_3">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Purpose"/>
    <rdfs:label>Gość automatycznie sięga po sztućce leżące na zewnątrz, i w ten sposób dostosowuje ich użycie do kolejności podawanych dań.</rdfs:label>

    <skos:notation>PDC-G 12</skos:notation>

    <hasEnablement>
