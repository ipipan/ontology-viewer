        </owl:NamedIndividual>
    </hasBroad>
    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_scislej_mowiac">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>Ściślej mówiąc,</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasSpecific>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Specific_4">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Specific"/>
            <rdfs:label>wymaga naprawdę niesamowitych umiejętności z zakresu Machine Learningu.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasSpecific>
</owl:NamedIndividual>


<!-- RESTATEMENT -->

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Restatement_1">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Restatement"/>
    <rdfs:label>Gdy klient nie miał już pieniędzy i przypomniał sobie o polisie, dowiadywał się w siedzibie towarzystwa o tak zwanym współczynniku wartości wykupu polisy. Innymi słowy, nie dostawał tego co wpłacił.</rdfs:label>

    <skos:notation>PDC-G 42</skos:notation>

    <hasArg1>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Arg1_Restatement">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Arg1"/>
            <rdfs:label>Gdy klient nie miał już pieniędzy i przypomniał sobie o polisie, dowiadywał się w siedzibie towarzystwa o tak zwanym współczynniku wartości wykupu polisy.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</skos:order>
        </owl:NamedIndividual>
    </hasArg1>
    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_innymi_slowy">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>Innymi słowy,</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasArg2>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Arg2_Restatement">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Arg2"/>
            <rdfs:label>nie dostawał tego co wpłacił.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasArg2>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Restatement_2">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Restatement"/>
    <rdfs:label>Jest bardzo zajęty, czyli nie ma teraz czasu.</rdfs:label>

    <skos:notation>PDC-G 43</skos:notation>

