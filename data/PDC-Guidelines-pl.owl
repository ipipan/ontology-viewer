    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Connective_zas">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
