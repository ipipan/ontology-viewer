<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Exception_2">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Exception"/>
    <rdfs:label>Wszystkie studentki musiały napisać test, z wyjątkiem tych sprytniejszych, które zdobyły zwolnienie lekarskie.</rdfs:label>

    <skos:notation>PDC-G 23</skos:notation>

    <hasRegular>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.PL.owl#Example_Regular_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Regular"/>
            <rdfs:label>Wszystkie studentki musiały napisać test,</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</skos:order>
        </owl:NamedIndividual>
    </hasRegular>
    <hasConnective>
