        </owl:NamedIndividual>
    </hasArg1>
    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Connective_In_other_words_39">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>In other words</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasArg2>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Example_Arg2_39">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Arg2"/>
            <rdfs:label>they treat you like a piece of meat</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasArg2>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Example_Restatement_2">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Restatement"/>
    <rdfs:label>Yet some people are advancing a chilling casuistry: that what we are seeing is somehow the understandable result of the historical sins committed by the Turks in the 16th century. Today’s Turks in Bulgaria, in other words, deserve what is coming to them four centuries later.</rdfs:label>

    <skos:notation>ISO-G 40</skos:notation>

    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Connective_Yet_some_people_are_advancing_a_chilling_casuistry_40">
