            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Arg1"/>
            <rdfs:label>that  what  we  are  seeing  is  somehow  the  understandable result of the historical sins committed by the Turks in the 16th century</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasArg1>
    <hasArg2>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Example_Arg2_40">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Arg2"/>
            <rdfs:label>Today’s  Turks  in  Bulgaria</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasArg2>
    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Connective_in_other_words_40_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>in  other  words</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
