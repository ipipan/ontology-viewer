<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Example_Asynchrony_3">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Asynchrony"/>
    <rdfs:label>The Artist has his routine. He spends his days sketching passers-by, or trying to. then At night he returns to the condemned building he calls home.</rdfs:label>

