<!-- ASYNCHRONY -->

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Example_Asynchrony">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Asynchrony"/>
    <rdfs:label>A buffet breakfast was held in the museum, where food and drinks are banned to everyday visitors. Then, in the guests’ honour, the speedway hauled out four drivers, crews and even the official Indianapolis 500 announcer for a 10-lap exhibition race.</rdfs:label>

    <skos:notation>ISO-G 44</skos:notation>

    <hasBefore>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Example_Before_44">
