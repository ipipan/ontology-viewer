            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Specific"/>
            <rdfs:label>they’d be able to say, I’m sorry, you can’t use this as evidence.</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasSpecific>
</owl:NamedIndividual>

<!-- RESTATEMENT -->

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Example_Restatement">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Restatement"/>
    <rdfs:label>Some days the coaches make you feel as though you are part of a large herd of animals. In other words, they treat you like a piece of meat.</rdfs:label>

    <skos:notation>ISO-G 39</skos:notation>

    <hasArg1>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Example_Arg1_39">
