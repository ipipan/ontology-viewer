    </hasConnective>
    <hasExpander>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Example_Expander_50">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Expander"/>
            <rdfs:label>A Dow spokeswoman declined to comment on the estimates</rdfs:label>
