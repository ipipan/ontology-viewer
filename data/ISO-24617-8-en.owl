            <rdfs:label>either</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasArg1>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Example_Arg1_30.2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Arg1"/>
            <rdfs:label>got a chair</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasArg1>
    <hasConnective>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Connective_or_30_2">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>or</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasArg2>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Example_Arg2_30">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Arg2"/>
