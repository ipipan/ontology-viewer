            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Connective"/>
            <rdfs:label>while</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</skos:order>
        </owl:NamedIndividual>
    </hasConnective>
    <hasArg2>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Example_Arg2_41">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Arg2"/>
            <rdfs:label>it attempts to work out a plan to pay its debts</rdfs:label>
            <skos:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</skos:order>
        </owl:NamedIndividual>
    </hasArg2>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Example_Synchrony_2">
    <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Synchrony"/>
    <rdfs:label>Then, in late-afternoon trading, hundred-thousand-share buy orders for UAL hit the market, including a 200,000-share order through Bear Stearns that seemed to spark UAL’s late price surge. Almost simultaneously, PaineWebber began a very visible buy program for dozens of stocks.</rdfs:label>

    <skos:notation>ISO-G 42</skos:notation>

    <hasArg1>
        <owl:NamedIndividual rdf:about="http://purl.org/olia/discourse/discourse.ISO.EN.owl#Example_Arg1_42">
            <rdf:type rdf:resource="http://purl.org/olia/discourse/discourse.ISO.UDisc.owl#Arg1"/>
            <rdfs:label>Then, in late-afternoon trading, hundred-thousand-share buy orders for UAL hit the market, including  a 200,000-share order through Bear Stearns that seemed to spark UAL’s late price surge</rdfs:label>
